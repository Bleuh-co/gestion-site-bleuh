# ======================================================================
# Firebase — client SDK (PUBLIC, exposé au navigateur)
# ======================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Domaines email autorisés (séparés par des virgules)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=chanv.com,bleuh.co,lafeuilleverte.ca,maisondherbes.com

# URL du Hub (widgets chatbot, feedback, Gandalf sidebar)
NEXT_PUBLIC_HUB_URL=

# ======================================================================
# Gestion des accès — ID Firestore de l'app Gestion Site Bleuh dans la
# collection `apps` du Hub Gandalf. Si défini, le code lit directement
# user_app_roles/{email}__{GESTIONSITEBLEUH_APP_ID} (zéro ambiguïté de nom).
# Sinon, fallback sur le matcher par nom.
# L'ID sera disponible après avoir ajouté l'app via l'interface du Hub.
# ======================================================================
GESTIONSITEBLEUH_APP_ID=

# ======================================================================
# Firebase Admin SDK — SERVEUR UNIQUEMENT
# JSON complet du service account sur une seule ligne (ou Secret Manager en prod)
# ======================================================================
FIREBASE_SERVICE_ACCOUNT_JSON=

# ======================================================================
# URL publique de l'app (utilisée dans les notifications, liens, etc.)
# ======================================================================
APP_PUBLIC_URL=

# ======================================================================
# Module Outils — proxy admin BleuhAPI — SERVEUR UNIQUEMENT
# BLEUHAPI_URL : défaut Cloud Run si vide (voir src/lib/bleuh-admin-proxy.ts)
# BLEUH_ADMIN_TOKEN : jamais exposé au client, jamais préfixé NEXT_PUBLIC_
# ======================================================================
BLEUHAPI_URL=
BLEUH_ADMIN_TOKEN=

# ======================================================================
# Module Analyse CEO — SERVEUR UNIQUEMENT
# ANTHROPIC_API_KEY : optionnelle. Absente → synthèse IA désactivée
#   (dégradation silencieuse, KPIs réels toujours calculés).
# BLEUHCHAT_PROJECT_ID : à poser UNIQUEMENT si le bot Bleuh (bleuh-chat)
#   tourne dans un projet Firestore différent de celui de
#   FIREBASE_SERVICE_ACCOUNT_JSON. Par défaut, réutilise le même client
#   Firestore (adminDb) — voir src/lib/firebase-admin.ts::chatDb().
# GA4_PROPERTY_ID : ID numérique de la propriété GA4 de SiteBleuh (sans le
#   préfixe "properties/"). Absente OU appel GA4 Data API en échec (SA sans
#   accès à la propriété) → source "non_instrumente", jamais de crash. Auth
#   via ADC (le SA du service doit avoir un accès Lecteur sur la propriété
#   GA4, Google Analytics Admin > Gestion des accès).
# ======================================================================
ANTHROPIC_API_KEY=
BLEUHCHAT_PROJECT_ID=
GA4_PROPERTY_ID=

# ======================================================================
# Module Shop — proxy admin WooCommerce (bleuh.shop) — SERVEUR UNIQUEMENT
# ⚠️ bleuh.shop est la boutique LIVE en production.
# WOO_STORE_URL : défaut https://bleuh.shop si vide (voir src/lib/woo-proxy.ts).
# WOO_CONSUMER_KEY / WOO_CONSUMER_SECRET : clés API REST WooCommerce v3 (Basic
#   auth ck/cs). JAMAIS exposées au client, JAMAIS préfixées NEXT_PUBLIC_,
#   JAMAIS commitées — vraies valeurs dans .env.local (gitignoré) / Secret Manager.
# ======================================================================
WOO_STORE_URL=
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=
